# Production build: full API base URL including `/api_project` (no trailing slash).
# Example: https://staging.homevision.co/api_project
# Leave unset to use the default staging URL in `fetchHousesPage.ts`.
# Local `pnpm dev` uses the Vite proxy (`/api` → staging); this variable is ignored in dev.
# VITE_API_BASE_URL=
